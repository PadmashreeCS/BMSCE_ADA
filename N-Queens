#include <stdio.h>

int board[10][10];
int n;
int count = 0;

// Check whether queen can be placed
int isSafe(int row, int col)
{
    // Check column
    for(int i = 0; i < row; i++)
    {
        if(board[i][col] == 1)
            return 0;
    }

    // Check left diagonal
    for(int i = row - 1, j = col - 1;
        i >= 0 && j >= 0;
        i--, j--)
    {
        if(board[i][j] == 1)
            return 0;
    }

    // Check right diagonal
    for(int i = row - 1, j = col + 1;
        i >= 0 && j < n;
        i--, j++)
    {
        if(board[i][j] == 1)
            return 0;
    }

    return 1;
}

// Print solution
void printBoard()
{
    count++;

    printf("\nSolution %d:\n", count);

    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            if(board[i][j] == 1)
                printf("Q ");
            else
                printf(". ");
        }
        printf("\n");
    }
}

// Backtracking
void nQueens(int row)
{
    // All queens placed
    if(row == n)
    {
        printBoard();
        return;
    }

    for(int col = 0; col < n; col++)
    {
        if(isSafe(row, col))
        {
            board[row][col] = 1;  // Place queen

            nQueens(row + 1);     // Next row (recursion call for next row)

            board[row][col] = 0;  // Backtrack
        }
    }
}

int main()
{
    printf("Enter N: ");
    scanf("%d", &n);

    nQueens(0);

    printf("\nTotal Solutions = %d\n", count);

    return 0;
}
