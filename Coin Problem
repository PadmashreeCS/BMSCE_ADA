#include <stdio.h>

int main()
{
    int n, m;

    printf("Enter rows and columns: ");
    scanf("%d %d", &n, &m);

    int coin[n][m];
    int F[n][m];

    printf("Enter coin matrix:\n");
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            scanf("%d", &coin[i][j]);
        }
    }

    F[0][0] = coin[0][0];

    // First row
    for(int j = 1; j < m; j++)
        F[0][j] = F[0][j-1] + coin[0][j];

    // First column
    for(int i = 1; i < n; i++)
        F[i][0] = F[i-1][0] + coin[i][0];

    // Remaining cells
    for(int i = 1; i < n; i++)
    {
        for(int j = 1; j < m; j++)
        {
            if(F[i-1][j] > F[i][j-1])
                F[i][j] = F[i-1][j] + coin[i][j];
            else
                F[i][j] = F[i][j-1] + coin[i][j];
        }
    }

    printf("\nMaximum coins collected = %d\n", F[n-1][m-1]);

    return 0;
}
