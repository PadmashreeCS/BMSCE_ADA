#include <stdio.h>

void heapify(int a[], int n, int i) // contract max heap
{
    int largest = i;
    int left = 2 * i + 1; // access left node from array
    int right = 2 * i + 2; // access right node from array
    int temp;

    // check which is having largest val left or rigt
    
    // Check left child,
    if(left < n && a[left] > a[largest])
        largest = left;

    // Check right child
    if(right < n && a[right] > a[largest])
        largest = right;

    // contract the max heap
    if(largest != i) // if child > parent swap 
    {
        temp = a[i];
        a[i] = a[largest];
        a[largest] = temp;

        heapify(a, n, largest); // again check for next parent 
    }
}

void heapSort(int a[], int n)
{
    int i, temp;

    // Build max heap
    for(i = n / 2 - 1; i >= 0; i--)
        heapify(a, n, i); // we need to check parent is having highest val, 5/2-1 =1 ( need to check 0-1 which mean only 2 noded haing child node, rest all left node) start from 1 beauce it is bottom to top approuch 

    // Extract elements one by one, (put last node at root node)
    for(i = n - 1; i >= 0; i--)
    {
        temp = a[0];
        a[0] = a[i];
        a[i] = temp;

        heapify(a, i, 0); // make max heap after swap
    }
}

int main()
{
    int a[100], n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    heapSort(a, n);

    printf("Sorted elements are:\n");

    for(i = 0; i < n; i++)
        printf("%d ", a[i]); // print sorted 

    return 0;
}
