#include <stdio.h>

struct Item {
    int profit;
    int weight;
    float ratio;
};

int main() {
    int n, capacity;

    printf("Enter number of items: ");
    scanf("%d", &n);

    struct Item item[n];

    for (int i = 0; i < n; i++) {
        printf("Enter profit and weight of item %d: ", i + 1);
        scanf("%d %d", &item[i].profit, &item[i].weight);

        item[i].ratio = (float)item[i].profit / item[i].weight;
    }

    printf("Enter knapsack capacity: ");
    scanf("%d", &capacity);

    // Sort by ratio (descending order)
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (item[i].ratio < item[j].ratio) {
                struct Item temp = item[i];
                item[i] = item[j];
                item[j] = temp;
            }
        }
    }

    float totalProfit = 0.0;

    printf("\nSelected Items:\n");

    for (int i = 0; i < n; i++) {
        if (capacity >= item[i].weight) {
            // Take whole item
            capacity -= item[i].weight;
            totalProfit += item[i].profit;

            printf("Item %d: 100%% taken\n", i + 1);
        }
        else {
            // Take fraction of item
            float fraction = (float)capacity / item[i].weight;
            totalProfit += item[i].profit * fraction;

            printf("Item %d: %.2f%% taken\n", i + 1, fraction * 100);

            capacity = 0;
            break;
        }
    }

    printf("\nMaximum Profit = %.2f\n", totalProfit);

    return 0;
}


