#include <stdio.h>

struct Item
{
    int profit;
    int weight;
    float ratio;
};

int main()
{
    int n, capacity, choice;

    printf("Enter number of items: ");
    scanf("%d", &n);

    struct Item item[n];

    for(int i = 0; i < n; i++)
    {
        printf("Enter profit and weight of item %d: ", i + 1);
        scanf("%d %d", &item[i].profit, &item[i].weight);

        item[i].ratio = (float)item[i].profit / item[i].weight;
    }

    printf("\nChoose Greedy Method:\n");
    printf("1. Based on Profit\n");
    printf("2. Based on Weight\n");
    printf("3. Based on Profit/Weight Ratio\n");
    printf("Enter choice: ");
    scanf("%d", &choice);

    printf("Enter Knapsack Capacity: ");
    scanf("%d", &capacity);

    /* Sorting according to selected method */
    for(int i = 0; i < n - 1; i++)
    {
        for(int j = i + 1; j < n; j++)
        {
            int swap = 0;

            if(choice == 1)   // Profit descending
            {
                if(item[i].profit < item[j].profit)
                    swap = 1;
            }
            else if(choice == 2) // Weight ascending
            {
                if(item[i].weight > item[j].weight)
                    swap = 1;
            }
            else if(choice == 3) // Ratio descending
            {
                if(item[i].ratio < item[j].ratio)
                    swap = 1;
            }

            if(swap)
            {
                struct Item temp = item[i];
                item[i] = item[j];
                item[j] = temp;
            }
        }
    }

    float totalProfit = 0;

    printf("\nSelected Items:\n");

    for(int i = 0; i < n; i++)
    {
        if(capacity == 0)
            break;

        if(capacity >= item[i].weight)
        {
            capacity -= item[i].weight;
            totalProfit += item[i].profit;

            printf("Item (P=%d, W=%d) -> 100%% taken\n",
                   item[i].profit, item[i].weight);
        }
        else
        {
            float fraction = (float)capacity / item[i].weight;

            totalProfit += item[i].profit * fraction;

            printf("Item (P=%d, W=%d) -> %.2f%% taken\n",
                   item[i].profit,
                   item[i].weight,
                   fraction * 100);

            capacity = 0;
        }
    }

    printf("\nTotal Profit = %.2f\n", totalProfit);

    return 0;
}
