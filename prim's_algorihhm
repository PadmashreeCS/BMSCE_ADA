#include <stdio.h>
#define V 4
#define INF 9999

int main() {
    int graph[V][V] = {
        {0, 2, 3, 0},
        {2, 0, 0, 1},
        {3, 0, 0, 4},
        {0, 1, 4, 0}
    };

    int VT[V] = {0};   // visited vertices
    int edges = 0;

    VT[0] = 1;   // Start with v0

    printf("Edges in MST:\n");

    while (edges < V - 1) {
        int min = INF;
        int u = -1, v = -1;

        // find minimum edge (u in VT, v not in VT)
        for (int i = 0; i < V; i++) {
            if (VT[i] == 1) {   // u ∈ VT
                for (int j = 0; j < V; j++) {
                    if (VT[j] == 0 && graph[i][j] != 0) {  // v ∉ VT
                        if (graph[i][j] < min) {
                            min = graph[i][j];
                            u = i;
                            v = j;
                        }
                    }
                }
            }
        }

        // add edge to MST
        printf("%d - %d : %d\n", u, v, min);

        VT[v] = 1;   // add vertex to VT
        edges++;
    }

    return 0;
}
