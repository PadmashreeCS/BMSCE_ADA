#include <stdio.h>

#define MAX 20

struct Edge
{
    int u, v, weight;
};

int parent[MAX];

// Find shortest parent of a vertex
int find(int i)
{
    while (parent[i] != i)
        i = parent[i];
    return i;
}

// Union of two sets (creting new path from given graph)
void unionSet(int a, int b)
{
    int rootA = find(a);
    int rootB = find(b);
    parent[rootB] = rootA;
}

// Sort edges by weight (Bubble Sort)
void sortEdges(struct Edge edges[], int e)
{
    int i, j;
    struct Edge temp;

    for (i = 0; i < e - 1; i++) // place the largest at last
    {
        for (j = 0; j < e - i - 1; j++) // after placeing highest at last, don't need to compare again last value so reduce by e-i-1
        {
            if (edges[j].weight > edges[j + 1].weight)
            {
                temp = edges[j];
                edges[j] = edges[j + 1];
                edges[j + 1] = temp;
            }
        }
    }
}

int main()
{
    int v, e, i;
    struct Edge edges[MAX];

    printf("Enter number of vertices: ");
    scanf("%d", &v);

    printf("Enter number of edges: ");
    scanf("%d", &e);

    printf("Enter edge details (source destination weight):\n");

    for (i = 0; i < e; i++)
    {
        scanf("%d %d %d",
              &edges[i].u,
              &edges[i].v,
              &edges[i].weight);
    }

    // Initialize parent array
    for (i = 0; i < v; i++)
        parent[i] = i;

    sortEdges(edges, e);

    int minCost = 0;
    int edgeCount = 0;

    printf("\nEdges in MST:\n");

    for (i = 0; i < e && edgeCount < v - 1; i++)
    {
        int uRoot = find(edges[i].u);
        int vRoot = find(edges[i].v);

        // If adding edge doesn't form a cycle
        if (uRoot != vRoot)
        {
            printf("%d -- %d = %d\n",
                   edges[i].u,
                   edges[i].v,
                   edges[i].weight);

            minCost += edges[i].weight;
            unionSet(uRoot, vRoot);
            edgeCount++;
        }
    }

    printf("\nMinimum Cost = %d\n", minCost);

    return 0;
}
